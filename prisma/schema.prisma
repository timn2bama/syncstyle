// Prisma schema for SyncStyle (Vercel Postgres)
// Based on Supabase data model

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  // Custom relations for SyncStyle
  wardrobe_items        WardrobeItem[]
  outfits               Outfit[]
  marketplace_items     MarketplaceItem[]
  rental_items          RentalItem[]
  saved_services        SavedService[]
  style_preference      UserStylePreference? @relation(fields: [userStylePreferenceId], references: [id])
  usage_tracking        UsageTracking[]
  subscriber            Subscriber?
  userStylePreferenceId String?

  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Profile {
  id           String   @id @default(uuid())
  user_id      String   @unique
  display_name String?
  avatar_url   String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("profiles")
}

model WardrobeItem {
  id              String    @id @default(uuid())
  user_id         String
  user            User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  name            String
  category        String
  brand           String?
  color           String?
  photo_url       String?
  description     String?
  wear_count      Int       @default(0)
  last_worn       DateTime?
  purchase_date   DateTime?
  dominant_color  String?
  color_palette   Json?
  detected_labels Json?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  outfit_items     OutfitItem[]
  marketplace_item MarketplaceItem?
  rental_item      RentalItem?
  analytics        WardrobeAnalytics[]
  carbon_footprint CarbonFootprintItem?

  @@map("wardrobe_items")
}

model Outfit {
  id          String   @id @default(uuid())
  user_id     String
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  name        String
  description String?
  occasion    String?
  season      String?
  is_public   Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  items     OutfitItem[]
  wear_logs OutfitWearLog[]
  likes     OutfitLike[]
  ratings   OutfitRating[]
  comments  OutfitComment[]

  @@map("outfits")
}

model OutfitItem {
  id               String   @id @default(uuid())
  outfit_id        String
  wardrobe_item_id String
  created_at       DateTime @default(now())

  outfit        Outfit       @relation(fields: [outfit_id], references: [id], onDelete: Cascade)
  wardrobe_item WardrobeItem @relation(fields: [wardrobe_item_id], references: [id], onDelete: Cascade)

  @@map("outfit_items")
}

model MarketplaceItem {
  id                   String    @id @default(uuid())
  seller_id            String
  wardrobe_item_id     String?   @unique
  title                String
  description          String?
  price                Float
  condition            String
  category             String
  size                 String?
  brand                String?
  photos               Json?
  is_available         Boolean   @default(true)
  shipping_included    Boolean   @default(false)
  sustainability_score Int?
  buyer_id             String?
  sold_at              DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  wardrobe_item WardrobeItem? @relation(fields: [wardrobe_item_id], references: [id])
  user          User?         @relation(fields: [userId], references: [id])
  userId        String?

  @@map("marketplace_items")
}

model RentalItem {
  id                String   @id @default(uuid())
  owner_id          String
  wardrobe_item_id  String?  @unique
  title             String
  description       String?
  daily_rate        Float
  weekly_rate       Float?
  deposit_amount    Float
  category          String
  size              String?
  brand             String?
  photos            Json?
  is_available      Boolean  @default(true)
  rental_terms      String?
  care_instructions String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  wardrobe_item WardrobeItem?   @relation(fields: [wardrobe_item_id], references: [id])
  bookings      RentalBooking[]
  user          User?           @relation(fields: [userId], references: [id])
  userId        String?

  @@map("rental_items")
}

model RentalBooking {
  id                   String   @id @default(uuid())
  rental_item_id       String
  renter_id            String
  start_date           DateTime
  end_date             DateTime
  status               String   @default("pending")
  total_cost           Float
  deposit_paid         Float
  return_condition     String?
  review_rating        Int?
  review_comment       String?
  special_instructions String?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  rental_item RentalItem @relation(fields: [rental_item_id], references: [id])

  @@map("rental_bookings")
}

model SavedService {
  id              String   @id @default(uuid())
  user_id         String
  service_name    String
  service_address String
  service_phone   String?
  service_data    Json
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  user            User?    @relation(fields: [userId], references: [id])
  userId          String?

  @@map("saved_services")
}

model DailyOutfitSuggestion {
  id               String   @id @default(uuid())
  user_id          String
  suggestion_date  DateTime
  outfit_data      Json
  ai_reasoning     String?
  occasion         String?
  style_preference String?
  weather_context  Json?
  user_feedback    String?
  was_worn         Boolean  @default(false)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@map("daily_outfit_suggestions")
}

model OutfitWearLog {
  id                 String   @id @default(uuid())
  user_id            String
  outfit_id          String?
  worn_date          DateTime @default(now())
  worn_at            DateTime @default(now())
  occasion           String?
  location           String?
  weather_temp       Float?
  weather_condition  String?
  comfort_rating     Int?
  style_satisfaction Int?
  mood_tags          String[]
  notes              String?
  items_worn         Json
  would_wear_again   Boolean?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  outfit Outfit? @relation(fields: [outfit_id], references: [id])

  @@map("outfit_wear_logs")
}

model WardrobeAnalytics {
  id               String    @id @default(uuid())
  user_id          String
  wardrobe_item_id String
  wear_count       Int       @default(0)
  total_cost       Float?
  cost_per_wear    Float?
  last_calculated  DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  wardrobe_item WardrobeItem @relation(fields: [wardrobe_item_id], references: [id])

  @@map("wardrobe_analytics")
}

model CarbonFootprintItem {
  id                    String   @id @default(uuid())
  user_id               String
  wardrobe_item_id      String   @unique
  manufacturing_impact  Float?
  transportation_impact Float?
  usage_impact          Float?
  disposal_impact       Float?
  total_footprint       Float?
  last_calculated       DateTime @default(now())
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  wardrobe_item WardrobeItem @relation(fields: [wardrobe_item_id], references: [id])

  @@map("carbon_footprint_items")
}

model IntegrationSetting {
  id               String   @id @default(uuid())
  user_id          String
  integration_type String
  settings         Json
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@map("integration_settings")
}

model UsageTracking {
  id                   String   @id @default(uuid())
  user_id              String
  usage_type           String
  usage_count          Int      @default(0)
  billing_period_start DateTime
  billing_period_end   DateTime
  created_at           DateTime @default(now())
  user                 User?    @relation(fields: [userId], references: [id])
  userId               String?

  @@map("usage_tracking")
}

model Subscriber {
  id           String    @id @default(uuid())
  user_id      String    @unique
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tier         String    @default("free")
  status       String    @default("active")
  period_start DateTime  @default(now())
  period_end   DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@map("subscribers")
}

model UserStylePreference {
  id              String   @id @default(uuid())
  user_id         String   @unique
  preferences     Json
  favorite_colors String[]
  disliked_colors String[]
  style_keywords  String[]
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  users           User[]

  @@map("user_style_preferences")
}

model OutfitLike {
  id         String   @id @default(uuid())
  user_id    String
  outfit_id  String
  created_at DateTime @default(now())

  outfit Outfit @relation(fields: [outfit_id], references: [id], onDelete: Cascade)

  @@unique([user_id, outfit_id])
  @@map("outfit_likes")
}

model OutfitRating {
  id         String   @id @default(uuid())
  user_id    String
  outfit_id  String
  rating     Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  outfit Outfit @relation(fields: [outfit_id], references: [id], onDelete: Cascade)

  @@unique([user_id, outfit_id])
  @@map("outfit_ratings")
}

model OutfitComment {
  id         String   @id @default(uuid())
  user_id    String
  outfit_id  String
  content    String
  created_at DateTime @default(now())

  outfit Outfit @relation(fields: [outfit_id], references: [id], onDelete: Cascade)

  @@map("outfit_comments")
}

model EventOutfitRequest {
  id                   String    @id @default(uuid())
  user_id              String
  event_title          String
  event_type           String?
  event_date           DateTime?
  dress_code           String?
  location             String?
  selected_outfit_id   String?
  special_requirements String?
  weather_requirements String?
  suggested_outfits    Json?
  status               String    @default("pending")
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  @@map("event_outfit_requests")
}

model StyleEvolutionTracking {
  id               String   @id @default(uuid())
  user_id          String
  tracking_date    DateTime @default(now())
  style_metrics    Json?
  achievements     String[]
  confidence_level Int?
  mood_tags        String[]
  style_goals      String[]
  insights         Json?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@map("style_evolution_tracking")
}

model SustainabilityMetric {
  id          String   @id @default(uuid())
  userId      String
  metricType  String
  value       Float
  unit        String
  periodStart DateTime
  periodEnd   DateTime
  sourceData  Json?
  createdAt   DateTime @default(now())

  @@map("sustainability_metrics")
}
